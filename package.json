{
  "name": "test-spec",
  "version": "0.1.0",
  "description": "Vitest reporter that generates Markdown test perspective reports grouped by Clean Architecture layers",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "vitest",
    "reporter",
    "test",
    "markdown",
    "clean-architecture",
    "test-perspective"
  ],
  "author": "imagepit",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "vitest": ">=3.0.0"
  }
}
